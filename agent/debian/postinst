#!/bin/sh
set -e

CONF_DIR=/etc/shellfleet
ENV_FILE="$CONF_DIR/env"
ENV_EXAMPLE="$CONF_DIR/env.example"
STATE_DIR=/var/lib/shellfleet
AGENT_STATE_DIR=/var/lib/shellfleet-agent
GATE_STATE_DIR=/var/lib/shellfleet-gate
PROBES_DIR="$CONF_DIR/probes.d"

case "$1" in
    configure|reconfigure)
        if ! getent group shellfleet >/dev/null; then
            addgroup --system shellfleet
        fi
        if ! getent passwd shellfleet >/dev/null; then
            adduser --system --ingroup shellfleet --home "$AGENT_STATE_DIR" \
                --no-create-home --disabled-login --disabled-password shellfleet
        fi

        # Make sure the config dir exists with safe perms.
        if [ ! -d "$CONF_DIR" ]; then
            mkdir -p "$CONF_DIR"
        fi
        chown root:shellfleet "$CONF_DIR"
        chmod 0750 "$CONF_DIR"

        install -d -o shellfleet -g shellfleet -m 0700 "$AGENT_STATE_DIR"
        install -d -o root -g root -m 0700 "$GATE_STATE_DIR"
        if [ -f "$CONF_DIR/agent-token.txt" ] && [ ! -f "$AGENT_STATE_DIR/agent-token.txt" ]; then
            install -o shellfleet -g shellfleet -m 0600 \
                "$CONF_DIR/agent-token.txt" "$AGENT_STATE_DIR/agent-token.txt"
        fi
        if [ ! -e "$CONF_DIR/approvers.json" ]; then
            printf '{}\n' > "$CONF_DIR/approvers.json"
            chown root:root "$CONF_DIR/approvers.json"
            chmod 0600 "$CONF_DIR/approvers.json"
        fi

        # Persistent state dir for apt-run journaling — survives reboot
        # so we can replay an apt run that was interrupted by libc /
        # systemd self-upgrades.
        if [ ! -d "$STATE_DIR" ]; then
            mkdir -p "$STATE_DIR"
            chown root:root "$STATE_DIR"
            chmod 0750 "$STATE_DIR"
        fi

        # Allow-list dir for exec-kind health probes. The agent will
        # only run scripts that live here (basename match, no path
        # traversal), so operators can drop scripts via configuration
        # management without exposing arbitrary code paths.
        if [ ! -d "$PROBES_DIR" ]; then
            mkdir -p "$PROBES_DIR"
        fi
        chown root:shellfleet "$PROBES_DIR"
        chmod 0750 "$PROBES_DIR"

        # Seed the stock probe library into /etc/shellfleet/probes.d/
        # exactly once, gated by a stamp file. After the seed has run,
        # operator deletions stick: `rm /etc/.../foo.sh` disables foo
        # forever. To pick up newly-added stock probes in a future
        # release, the operator runs:
        #   ln -s /usr/share/shellfleet/probes.d/<name>.sh \
        #         /etc/shellfleet/probes.d/
        STOCK_DIR=/usr/share/shellfleet/probes.d
        SEED_STAMP="$STATE_DIR/.probes-seeded"
        if [ ! -e "$SEED_STAMP" ] && [ -d "$STOCK_DIR" ]; then
            for src in "$STOCK_DIR"/*.sh; do
                [ -f "$src" ] || continue
                name=$(basename "$src")
                target="$PROBES_DIR/$name"
                if [ ! -e "$target" ] && [ ! -L "$target" ]; then
                    ln -s "$src" "$target"
                fi
            done
            touch "$SEED_STAMP"
            chmod 0644 "$SEED_STAMP"
        fi

        # Seed /etc/shellfleet/env on first install. Never overwrite an
        # existing operator-edited file on upgrade.
        if [ ! -e "$ENV_FILE" ] && [ -e "$ENV_EXAMPLE" ]; then
            cp "$ENV_EXAMPLE" "$ENV_FILE"
            chown root:shellfleet "$ENV_FILE"
            chmod 0640 "$ENV_FILE"
        fi

        if command -v apparmor_parser >/dev/null 2>&1; then
            apparmor_parser -r /etc/apparmor.d/shellfleet-agent || true
            apparmor_parser -r /etc/apparmor.d/shellfleet-approval-gate || true
            apparmor_parser -r /etc/apparmor.d/shellfleet-docker-proxy || true
        fi
        systemctl daemon-reload >/dev/null 2>&1 || true
        systemctl enable shellfleet-approval-gate.service >/dev/null 2>&1 || true
        ;;
esac

#DEBHELPER#

exit 0
