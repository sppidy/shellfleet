# sys-manager-agent runtime configuration.
# Copy or rename to /etc/sys-manager/env and edit, then:
#   systemctl restart sys-manager-agent
#
# All variables are optional. Defaults point at the public sppidy.in deploy.

# Server HTTPS URL used for the device-auth pairing flow.
#SERVER_API_URL=https://dashboard.example.com

# Server WebSocket URL the agent connects to.
#SERVER_WS_URL=wss://dashboard.example.com/agent/ws

# ─── S3 backups (optional) ────────────────────────────────────────────
#
# When a backup job's destination is `s3://bucket/prefix`, the agent
# uploads via aws-sdk-s3 (no aws CLI needed). Standard AWS env vars
# work; AWS_ENDPOINT_URL routes to any S3-compatible provider so the
# project doesn't lock you into AWS.
#
# AWS:
#AWS_REGION=us-east-1
#AWS_ACCESS_KEY_ID=AKIA…
#AWS_SECRET_ACCESS_KEY=…
#
# MinIO (self-hosted):
#AWS_ENDPOINT_URL=https://minio.your-domain.example
#AWS_ACCESS_KEY_ID=…           # MinIO user key
#AWS_SECRET_ACCESS_KEY=…
#AWS_REGION=us-east-1          # any value, ignored by MinIO
#
# Cloudflare R2:
#AWS_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
#AWS_ACCESS_KEY_ID=…           # R2 token id
#AWS_SECRET_ACCESS_KEY=…
#AWS_REGION=auto
#
# Backblaze B2 (S3-compat):
#AWS_ENDPOINT_URL=https://s3.us-west-002.backblazeb2.com
#AWS_ACCESS_KEY_ID=…           # B2 keyID
#AWS_SECRET_ACCESS_KEY=…       # B2 applicationKey
#AWS_REGION=us-west-002
#
# Wasabi, Linode Object Storage, DigitalOcean Spaces, etc. all work
# the same way — set AWS_ENDPOINT_URL + the AWS_REGION their docs say
# to use, and the SDK handles the rest.
