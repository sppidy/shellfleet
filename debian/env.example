# sys-manager-agent runtime configuration.
# Copy or rename to /etc/sys-manager/env and edit, then:
#   systemctl restart sys-manager-agent
#
# All variables are optional. Defaults point at the public sppidy.in deploy.

# Server HTTPS URL used for the device-auth pairing flow.
#SERVER_API_URL=https://dashboard.example.com

# Server WebSocket URL the agent connects to.
#SERVER_WS_URL=wss://dashboard.example.com/agent/ws
