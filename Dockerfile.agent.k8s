# Multi-stage build for the shellfleet-agent k8s flavor.
# Same source as the host-agent .deb, just with `--features kube` so
# the binary advertises the `"k8s"` capability and handles the
# K8sList* / K8sDescribe / K8sLogs* / K8sExec* variants.

FROM rust:1-bookworm AS builder

WORKDIR /src
COPY agent/  /src/agent/
COPY shared/ /src/shared/

# Trim the workspace to what we actually build.
RUN cat > /src/Cargo.toml <<'EOF'
[workspace]
members = ["agent", "shared"]
resolver = "2"
EOF

WORKDIR /src/agent
RUN cargo build --release --features kube
RUN strip /src/target/release/shellfleet-agent

# ─────────────────────────────────────────────────────────────────
FROM debian:bookworm-slim AS runtime

RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates && \
    rm -rf /var/lib/apt/lists/*

COPY --from=builder /src/target/release/shellfleet-agent /usr/bin/shellfleet-agent

# Token directory — pre-create with mode 0700 so the agent can write
# the bearer token after pairing without touching /etc permissions.
RUN install -d -m 0700 /etc/shellfleet

ENTRYPOINT ["/usr/bin/shellfleet-agent"]
