#include <tunables/global>

profile shellfleet-agent /usr/bin/shellfleet-agent flags=(attach_disconnected,mediate_deleted) {
  #include <abstractions/base>
  #include <abstractions/nameservice>
  #include <abstractions/ssl_certs>

  network inet stream,
  network inet6 stream,
  network unix stream,

  /usr/bin/shellfleet-agent mr,
  /var/lib/shellfleet-agent/** rwk,
  /etc/shellfleet/env r,
  /etc/shellfleet/probes.d/* rix,
  /usr/share/shellfleet/probes.d/* rix,
  / r,
  /dev/ptmx rw,
  /dev/pts/** rw,
  /run/dbus/system_bus_socket rw,
  # Service discovery/control uses systemd's manager interface. systemd's
  # native D-Bus authorization remains the privilege boundary for each call.
  dbus (send, receive)
      bus=system
      path=/org/freedesktop/systemd1
      interface=org.freedesktop.systemd1.Manager
      peer=(name=org.freedesktop.systemd1),
  /run/shellfleet/approval-gate.sock rw,
  # The optional root-owned proxy exposes this socket only after an operator
  # explicitly enables it with `shellfleet-docker-proxy enable`.
  /run/shellfleet/docker.sock rw,
  /proc/** r,
  /sys/** r,
  /etc/hostname r,
  /etc/os-release r,
  /usr/bin/** rix,
  /bin/** rix,
  # Docker CLI probes these directories for optional client plugins before
  # every invocation. Read-only discovery keeps normal Docker commands quiet
  # without granting execution of plugin code.
  /usr/lib/docker/cli-plugins/** r,
  /usr/libexec/docker/cli-plugins/** r,

  deny /run/docker.sock rw,
  deny /var/run/docker.sock rw,
  deny /etc/shellfleet/approvers.json rw,
  deny /var/lib/shellfleet-gate/** rwklx,
  deny /etc/sudoers{,/**} rwklx,
  deny /root/** rwklx,
  deny /dev/mem rwklx,
  deny capability,
  deny ptrace,
}
