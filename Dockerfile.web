# Pinned to a specific Node 20 LTS digest channel (alpine 3.21) so a
# silent upstream Node release can't change the produced bundle
# behaviour mid-deploy. Bump deliberately when it's time.
FROM node:20.19-alpine3.21 AS builder
WORKDIR /app
COPY web/package*.json ./
RUN npm ci --no-audit --no-fund
COPY web/ ./
RUN npm run build

FROM node:20.19-alpine3.21 AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000

# next.config.ts has `output: "standalone"`, so the build emits a tiny
# self-contained server at .next/standalone/. Copy only that + the
# static assets (.next/static) + public/ — drops ~1 GB of dev deps.
COPY --from=builder /app/.next/standalone/ ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

# `node:*-alpine` ships with a pre-baked uid 1000 `node` user.
# Drop privileges before running the standalone server. The web
# container has no writable state; chowning the working tree
# isn't strictly necessary, but doing it makes the runtime
# read-only-rootfs friendly.
RUN chown -R node:node /app
USER node:node
EXPOSE 3000
CMD ["node", "server.js"]
