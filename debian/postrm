#!/bin/sh
set -e

CONF_DIR=/etc/shellfleet
TOKEN_FILE="$CONF_DIR/agent-token.txt"

case "$1" in
    purge)
        # On purge, remove the cached pairing token. The operator-edited
        # env file is also cleared so a future install starts fresh.
        rm -f "$TOKEN_FILE" "$CONF_DIR/env" "$CONF_DIR/env.example" \
            "$CONF_DIR/docker-proxy.env"
        # Best-effort directory removal; ignore failure if non-empty.
        rmdir "$CONF_DIR" 2>/dev/null || true
        ;;
esac

#DEBHELPER#

exit 0
