# shellfleet-agent runtime configuration.
# Copy or rename to /etc/shellfleet/env and edit, then:
#   systemctl restart shellfleet-agent
#
# All variables are optional. Defaults point at the public sppidy.in deploy.

# Server HTTPS URL used for the device-auth pairing flow.
#SERVER_API_URL=https://dashboard.example.com

# Server WebSocket URL the agent connects to.
#SERVER_WS_URL=wss://dashboard.example.com/agent/ws

# ─── Docker and Swarm (optional, explicit opt-in) ──────────────────────
#
# Do not add DOCKER_HOST here manually. To allow the agent to manage local
# Docker containers and Swarm, run this as root instead:
#
#   shellfleet-docker-proxy enable
#
# The helper creates a separate root-owned configuration file and enables a
# narrowly-scoped local proxy. Docker API access is root-equivalent on typical
# Docker hosts, so enable it only when you trust this ShellFleet server and its
# administrators. Disable it again with:
#
#   shellfleet-docker-proxy disable

# ─── One-shot command execution (optional, default-deny) ─────────────
#
# Runbooks and /api/v1 exec requests are rejected locally unless the complete
# command exactly matches one entry in this JSON array. Prefixes and wildcards
# are intentionally unsupported because commands execute through `sh -c`.
#SHELLFLEET_EXEC_ALLOW_JSON='["uptime","systemctl restart nginx"]'

# ─── Kubernetes apply (K8s package only, optional) ────────────────
#
# Server-side apply is disabled until an explicit namespace allow-list is set.
# Only common namespaced resource kinds are accepted; RBAC, cluster-scoped and
# custom resources, forced ownership, privileged pod settings, host mounts, and
# service-account token mounts are rejected locally by the agent.
#SHELLFLEET_K8S_APPLY_NAMESPACES=apps,staging

# ─── S3 backups (optional) ────────────────────────────────────────────
#
# When a backup job's destination is `s3://bucket/prefix`, the agent
# uploads via aws-sdk-s3 (no aws CLI needed). Standard AWS env vars
# work; AWS_ENDPOINT_URL routes to any S3-compatible provider so the
# project doesn't lock you into AWS.
#
# AWS:
#AWS_REGION=us-east-1
#AWS_ACCESS_KEY_ID=AKIA…
#AWS_SECRET_ACCESS_KEY=…
#
# MinIO (self-hosted):
#AWS_ENDPOINT_URL=https://minio.your-domain.example
#AWS_ACCESS_KEY_ID=…           # MinIO user key
#AWS_SECRET_ACCESS_KEY=…
#AWS_REGION=us-east-1          # any value, ignored by MinIO
#
# Cloudflare R2:
#AWS_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
#AWS_ACCESS_KEY_ID=…           # R2 token id
#AWS_SECRET_ACCESS_KEY=…
#AWS_REGION=auto
#
# Backblaze B2 (S3-compat):
#AWS_ENDPOINT_URL=https://s3.us-west-002.backblazeb2.com
#AWS_ACCESS_KEY_ID=…           # B2 keyID
#AWS_SECRET_ACCESS_KEY=…       # B2 applicationKey
#AWS_REGION=us-west-002
#
# Wasabi, Linode Object Storage, DigitalOcean Spaces, etc. all work
# the same way — set AWS_ENDPOINT_URL + the AWS_REGION their docs say
# to use, and the SDK handles the rest.

# Backup and restore paths are confined by default to /var/lib/shellfleet
# and /var/backups/shellfleet. Replace those roots when a backup job needs a
# specific additional path; colon-separate multiple paths.
#SHELLFLEET_BACKUP_ROOTS=/srv/shellfleet-data:/var/backups/shellfleet
#
# Do not enable this unless the server is fully trusted: it permits backup and
# restore jobs to access any path the shellfleet service account can access.
#SHELLFLEET_ALLOW_UNRESTRICTED_BACKUPS=1
