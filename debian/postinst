#!/bin/sh
set -e

CONF_DIR=/etc/sys-manager
ENV_FILE="$CONF_DIR/env"
ENV_EXAMPLE="$CONF_DIR/env.example"
STATE_DIR=/var/lib/sys-manager
PROBES_DIR="$CONF_DIR/probes.d"

case "$1" in
    configure|reconfigure)
        # Make sure the config dir exists with safe perms.
        if [ ! -d "$CONF_DIR" ]; then
            mkdir -p "$CONF_DIR"
            chown root:root "$CONF_DIR"
            chmod 0750 "$CONF_DIR"
        fi

        # Persistent state dir for apt-run journaling — survives reboot
        # so we can replay an apt run that was interrupted by libc /
        # systemd self-upgrades.
        if [ ! -d "$STATE_DIR" ]; then
            mkdir -p "$STATE_DIR"
            chown root:root "$STATE_DIR"
            chmod 0750 "$STATE_DIR"
        fi

        # Allow-list dir for exec-kind health probes. The agent will
        # only run scripts that live here (basename match, no path
        # traversal), so operators can drop scripts via configuration
        # management without exposing arbitrary code paths.
        if [ ! -d "$PROBES_DIR" ]; then
            mkdir -p "$PROBES_DIR"
            chown root:root "$PROBES_DIR"
            chmod 0750 "$PROBES_DIR"
        fi

        # Seed the stock probe library into /etc/sys-manager/probes.d/
        # exactly once, gated by a stamp file. After the seed has run,
        # operator deletions stick: `rm /etc/.../foo.sh` disables foo
        # forever. To pick up newly-added stock probes in a future
        # release, the operator runs:
        #   ln -s /usr/share/sys-manager/probes.d/<name>.sh \
        #         /etc/sys-manager/probes.d/
        STOCK_DIR=/usr/share/sys-manager/probes.d
        SEED_STAMP="$STATE_DIR/.probes-seeded"
        if [ ! -e "$SEED_STAMP" ] && [ -d "$STOCK_DIR" ]; then
            for src in "$STOCK_DIR"/*.sh; do
                [ -f "$src" ] || continue
                name=$(basename "$src")
                target="$PROBES_DIR/$name"
                if [ ! -e "$target" ] && [ ! -L "$target" ]; then
                    ln -s "$src" "$target"
                fi
            done
            touch "$SEED_STAMP"
            chmod 0644 "$SEED_STAMP"
        fi

        # Seed /etc/sys-manager/env on first install. Never overwrite an
        # existing operator-edited file on upgrade.
        if [ ! -e "$ENV_FILE" ] && [ -e "$ENV_EXAMPLE" ]; then
            cp "$ENV_EXAMPLE" "$ENV_FILE"
            chown root:root "$ENV_FILE"
            chmod 0640 "$ENV_FILE"
        fi
        ;;
esac

#DEBHELPER#

exit 0
