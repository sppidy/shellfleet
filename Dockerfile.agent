FROM rust:latest AS builder
WORKDIR /usr/src/app
COPY . .
RUN cargo build --release -p agent

FROM debian:bookworm-slim
WORKDIR /app
# Install systemd, dbus, and bash (needed for portable-pty and systemctl commands)
RUN apt-get update && apt-get install -y systemd dbus bash && rm -rf /var/lib/apt/lists/*
COPY --from=builder /usr/src/app/target/release/shellfleet-agent /app/agent
CMD ["./agent"]
