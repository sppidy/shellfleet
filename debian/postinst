#!/bin/sh
set -e

CONF_DIR=/etc/sys-manager
ENV_FILE="$CONF_DIR/env"
ENV_EXAMPLE="$CONF_DIR/env.example"
STATE_DIR=/var/lib/sys-manager

case "$1" in
    configure|reconfigure)
        # Make sure the config dir exists with safe perms.
        if [ ! -d "$CONF_DIR" ]; then
            mkdir -p "$CONF_DIR"
            chown root:root "$CONF_DIR"
            chmod 0750 "$CONF_DIR"
        fi

        # Persistent state dir for apt-run journaling — survives reboot
        # so we can replay an apt run that was interrupted by libc /
        # systemd self-upgrades.
        if [ ! -d "$STATE_DIR" ]; then
            mkdir -p "$STATE_DIR"
            chown root:root "$STATE_DIR"
            chmod 0750 "$STATE_DIR"
        fi

        # Seed /etc/sys-manager/env on first install. Never overwrite an
        # existing operator-edited file on upgrade.
        if [ ! -e "$ENV_FILE" ] && [ -e "$ENV_EXAMPLE" ]; then
            cp "$ENV_EXAMPLE" "$ENV_FILE"
            chown root:root "$ENV_FILE"
            chmod 0640 "$ENV_FILE"
        fi
        ;;
esac

#DEBHELPER#

exit 0
