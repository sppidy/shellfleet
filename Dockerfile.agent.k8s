# Multi-stage build for the shellfleet-agent k8s flavor.
# Same source as the host-agent .deb, just with `--features kube` so
# the binary advertises the `"k8s"` capability and handles the
# K8sList* / K8sDescribe / K8sLogs* / K8sExec* variants.

FROM rust:1-bookworm AS builder

WORKDIR /src
COPY Cargo.toml Cargo.lock /src/
COPY agent/  /src/agent/
COPY shared/ /src/shared/
COPY server/ /src/server/

RUN cargo build --locked --release -p agent --features kube
RUN strip /src/target/release/shellfleet-agent

# ─────────────────────────────────────────────────────────────────
FROM debian:bookworm-slim AS runtime

RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates && \
    rm -rf /var/lib/apt/lists/*

COPY --from=builder /src/target/release/shellfleet-agent /usr/bin/shellfleet-agent

# Run unprivileged: the k8s agent reaches the cluster API via its mounted
# ServiceAccount token, never host privileges.
RUN useradd -r -u 10001 -s /usr/sbin/nologin shellfleet

# Token directory — owned by the agent user, mode 0700, so it can persist the
# bearer token after pairing without touching root-owned paths.
RUN install -d -m 0700 -o shellfleet -g shellfleet /etc/shellfleet

USER 10001
ENTRYPOINT ["/usr/bin/shellfleet-agent", "--pair"]
